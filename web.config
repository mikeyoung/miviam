<?xml version="1.0" encoding="UTF-8"?>
<!--
  MiViAm — IIS config for serving the static PWA (e.g. https://mikeyoung.org/miviam/).
  - Correct MIME types for the PWA manifest and audio (IIS doesn't know .webmanifest/.ogg by default).
  - index.html as the folder default document.
  - service-worker.js served no-cache so SW updates are picked up promptly.
-->
<configuration>
  <system.webServer>
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>
    <staticContent>
      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
      <remove fileExtension=".ogg" />
      <mimeMap fileExtension=".ogg" mimeType="audio/ogg" />
      <remove fileExtension=".m4a" />
      <mimeMap fileExtension=".m4a" mimeType="audio/mp4" />
      <remove fileExtension=".mp3" />
      <mimeMap fileExtension=".mp3" mimeType="audio/mpeg" />
      <remove fileExtension=".wav" />
      <mimeMap fileExtension=".wav" mimeType="audio/wav" />
    </staticContent>
  </system.webServer>
  <!-- Never cache the service worker, so new versions activate quickly. -->
  <location path="service-worker.js">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="DisableCache" />
      </staticContent>
    </system.webServer>
  </location>
</configuration>
